{
  "spec": "ArchiMate 3.2",
  "note": "Element catalog, aspect-based allowed-relationship rules, PlantUML stdlib macro map, and Open Exchange xsi:type rules. The relationship rules are an aspect-category approximation of ArchiMate 3.2 Appendix B (the full relationship matrix): generous via Association, conservative elsewhere. See references/metamodel-and-relationships.md.",

  "aspects": ["active", "behavior", "passive", "motivation", "composite", "connector"],

  "layers": ["motivation", "strategy", "business", "application", "technology", "physical", "implementation", "composite", "connector"],

  "elements": {
    "Stakeholder":            {"layer": "motivation",     "aspect": "motivation"},
